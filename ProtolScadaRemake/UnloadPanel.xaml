<UserControl x:Class="ProtolScadaRemake.UnloadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Name="UnloadControl"
             Background="Transparent"
             Width="200" 
             Height="376">
    <!-- Увеличил высоту для новой кнопки -->

    <Border BorderBrush="#666666" 
            BorderThickness="1"
            Background="Transparent"
            CornerRadius="6"
            Padding="10" Margin="0,0,0,0">

        <StackPanel>
            <!-- Заголовок панели -->
            <TextBlock Text="ОТГРУЗКА"
                       FontWeight="Bold"
                       FontSize="14"
                       Foreground="White"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

            <!-- Режим и стадия в одной строке -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Режим отгрузки -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="РЕЖИМ"
                               FontSize="11"
                               Foreground="White"
                               Margin="0,0,0,2"/>
                    <Border CornerRadius="3"
                            Padding="4,2"
                            Background="#808080">
                        <TextBlock x:Name="ModeText"
                                   Text="ПУЛЬТ"
                                   FontSize="11"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Стадия отгрузки -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="СТАДИЯ"
                               FontSize="11"
                               Foreground="White"
                               Margin="0,0,0,2"/>
                    <Border CornerRadius="3"
                            Padding="4,2"
                            Background="#808080">
                        <TextBlock x:Name="StageText"
                                   Text="СТОП"
                                   FontSize="11"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Управление параметрами -->
            <Border Background="Transparent"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,0,0,10">

                <StackPanel>
                    <!-- Скорость -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="СКОРОСТЬ"
                                   FontSize="11"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="SpeedTextBox"
                                 Grid.Column="1"
                                 Height="22"
                                 FontSize="11"
                                 Foreground="White"
                                 Background="#444444"
                                 BorderBrush="#666666"
                                 Text="0"
                                 TextAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="5,0,5,0"/>

                        <TextBlock Grid.Column="2"
                                   Text=""
                                   FontSize="11"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Время/вес -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="AmountLabel"
                                   Text="ВРЕМЯ"
                                   FontSize="11"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <TextBox x:Name="AmountTextBox"
                                 Grid.Column="1"
                                 Height="22"
                                 FontSize="11"
                                 Foreground="White"
                                 Background="#444444"
                                 BorderBrush="#666666"
                                 Text="0"
                                 TextAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="5,0,5,0"/>

                        <TextBlock x:Name="AmountUnit"
                                   Grid.Column="2"
                                   Text=""
                                   FontSize="11"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Кнопки управления параметрами -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button x:Name="SetParamsButton"
                                Content="УСТАН."
                                Width="60"
                                Height="24"
                                Background="#FF1E5945"
                                BorderBrush="#FF00FF00"
                                BorderThickness="1"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="Bold"
                                Margin="0,0,4,0"
                                Click="SetParamsButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" 
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="ResetButton"
                                Content="СБРОС"
                                Width="60"
                                Height="24"
                                Background="#7B001C"
                                BorderBrush="#FF0033"
                                BorderThickness="1"
                                Foreground="White"
                                FontSize="11"
                                FontWeight="Bold"
                                Click="ResetButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" 
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Отгружено -->
            <Border Background="#1E3A5F"
                    CornerRadius="4"
                    Padding="6"
                    Margin="0,0,0,10">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ОТГРУЖЕНО"
                               FontSize="11"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <TextBlock x:Name="UnloadedValue"
                               Grid.Column="1"
                               Text="0"
                               FontWeight="Bold"
                               FontSize="13"
                               Foreground="#4CAF50"
                               VerticalAlignment="Center"
                               Margin="5,0,2,0"/>

                    <TextBlock x:Name="UnloadedUnit"
                               Grid.Column="2"
                               Text=""
                               FontSize="11"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Кнопка Тарирование (как в старом проекте) -->
            <Button x:Name="TorirovanieButton"
                    Content="ТАРИРОВАНИЕ"
                    Width="160"
                    Height="28"
                    Background="#FF8C00"
                    BorderBrush="#FFA500"
                    BorderThickness="1"
                    Foreground="White"
                    FontSize="11"
                    FontWeight="Bold"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Center"
                    Click="TorirovanieButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Кнопки выбора режима -->
            <StackPanel>
                <!-- Кнопка ПУЛЬТ -->
                <Button x:Name="PultModeButton"
                        Content="ПУЛЬТ"
                        Background="#3F51B5"
                        BorderBrush="#2196F3"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                        Height="28"
                        Margin="0,0,0,5"
                        Click="PultMode_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Кнопка ПО ВРЕМЕНИ -->
                <Button x:Name="TimeModeButton"
                        Content="ПО ВРЕМЕНИ"
                        Background="#2196F3"
                        BorderBrush="#4FC3F7"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                        Height="28"
                        Margin="0,0,0,5"
                        Click="TimeMode_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Кнопка ПО ВЕСУ -->
                <Button x:Name="MassModeButton"
                        Content="ПО ВЕСУ"
                        Background="#FF1E5945"
                        BorderBrush="#FF00FF00"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="11"
                        FontWeight="Bold"
                        Height="28"
                        Click="MassMode_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>