<UserControl x:Class="ProtolScadaRemake.Element_PumpUzUnderPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProtolScadaRemake"
      mc:Ignorable="d" MouseDown="ValueLabel_Click" Height="80">

    <Grid Width="184" Height="80" VerticalAlignment="Center" HorizontalAlignment="Left">
        <Grid Margin="0,0,0,-29">
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="60"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <!-- Строка 1: Тэг и рука -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="TAGNAME" 
                           Grid.Column="1"
                           TextWrapping="Wrap" 
                           Text="TAG" 
                           FontFamily="Arial" 
                           Foreground="White" 
                           TextAlignment="Left"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Left"
                           Margin="15,10,0,0"/>
            </Grid>

            <!-- Строка 2: Насос по центру -->
            <Grid Grid.Row="1">
                <Image x:Name="PumpIcon" 
                       Source="{StaticResource PumpHStopIcon}" 
                       Width="60" 
                       Height="60" 
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                <Image x:Name="HandImage" 
                       Grid.Column="0"
                       Height="24" 
                       Width="20" 
                       Source="/Hand.png"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Left"
                       Margin="122,0,0,0"/>
            </Grid>

            <!-- Строка 3: Панель скорости -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="62"/>
                    <ColumnDefinition Width="90"/>
                </Grid.ColumnDefinitions>

                <!-- Контейнер с закруглёнными краями -->
                <Border Grid.Column="1"
                        CornerRadius="6"
                        Background="#444444"
                        BorderBrush="#FF5D5D5D"
                        BorderThickness="1"
                        Height="20"
                        Width="90"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="-10,0,0,0"
                        ClipToBounds="True">

                    <!-- Заполнение (зелёное) -->
                    <Border x:Name="SpeedFill"
                            CornerRadius="5"
                            Background="#FF1E5945"
                            HorizontalAlignment="Left"
                            Width="0"
                            Margin="1"/>
                </Border>

                <!-- Текст скорости -->
                <TextBlock x:Name="SpeedText" 
                           Grid.Column="1"
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Center" 
                           TextWrapping="Wrap" 
                           Text="0 %"
                           FontFamily="Arial"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="-5,0,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>