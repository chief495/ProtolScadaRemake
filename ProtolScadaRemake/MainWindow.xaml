<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProtolScadaRemake" x:Class="ProtolScadaRemake.MainWindow"
        Title="Система диспетчерского управления технологическим процессом" 
        Height="1080" Width="1920"
        Icon="Images/ProtolLogo.ico"
        WindowState="Maximized"
        Closing="MainWindow_Closed" WindowStyle="None">

    <Window.Resources>
        <!-- Стиль для текста счетчика аварий -->
        <Style x:Key="FaultCounterTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="17"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="170"/>
        </Grid.ColumnDefinitions>

        <!-- TOP PANEL -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#070142">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="261"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="97"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/ProtolLogo.ico"
                        Width="72" Height="64"/>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="ПРОТОЛ" 
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="БУРОВЗРЫВНЫЕ РАБОТЫ" 
                                   FontWeight="Bold" FontSize="12"
                                   Foreground="White"/>
                    </StackPanel>
                </StackPanel>

                <!-- КНОПКА ДОСТУПА (слева от заголовка) -->
                <Button x:Name="AccessButton" 
                        Grid.Column="1"
                        Width="90"
                        Height="32"
                        Margin="15,0,0,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="AccessButton_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="AccessBorder" 
                                    Background="#1E2A3A" 
                                    CornerRadius="16" 
                                    BorderBrush="#3A4F6E" 
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Индикатор состояния (кружок) -->
                                    <Border Grid.Column="0" 
                                            x:Name="StatusIndicator" 
                                            Width="10" 
                                            Height="10" 
                                            CornerRadius="5" 
                                            Background="#888" 
                                            HorizontalAlignment="Center"
                                            Margin="9,0,0,0"/>

                                    <!-- Текст -->
                                    <TextBlock Grid.Column="1" 
                                               x:Name="AccessText" 
                                               Text="ДОСТУП" 
                                               Foreground="#CCC" 
                                               FontWeight="Bold" 
                                               FontSize="9"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Margin="2,0,0,0"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- Состояние при наведении -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="AccessBorder" Property="Background" Value="#2A3A4A"/>
                                    <Setter TargetName="AccessBorder" Property="BorderBrush" Value="#5A7F9F"/>
                                </Trigger>
                                <!-- Состояние при нажатии -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="AccessBorder" Property="Background" Value="#1A2A3A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Title -->
                <TextBlock x:Name="TitleLabel" Grid.Column="2" 
                           Text="ОСНОВНОЙ ЭКРАН" 
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Top" Margin="372,22,0,0"/>

                <!-- Панель счетчика аварий -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/FaultsActive.png" 
                           Width="24" Height="24" Margin="0,0,5,0"/>
                    <Border Background="#FFFF0000" CornerRadius="10" Padding="8,2" Margin="5,0,0,0">
                        <TextBlock x:Name="FaultCounterLabel" 
                                   Text="0" 
                                   Style="{StaticResource FaultCounterTextStyle}"/>
                    </Border>
                </StackPanel>

                <!-- Time -->
                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock x:Name="DateLabel" Text="00.00.0000" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TimeLabel" Text="00:00:00" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Border Grid.Row="1" Grid.Column="0" Background="#ff1a263d">
            <Grid x:Name="ContentGrid" Height="1000">
                <TextBlock Text="Выберите раздел" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="24"
                           Foreground="Gray"/>
            </Grid>
        </Border>

        <!-- RIGHT MENU -->
        <StackPanel Grid.Row="1" Grid.Column="1" Background="#070142">
            <!-- Основной экран -->
            <Button x:Name="MainPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Active">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Одно изображение, которое меняется в зависимости от состояния -->
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Активное состояние (Tag = "Active") - ВЫСШИЙ ПРИОРИТЕТ -->
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource MenuButtonActive}"/>
                            </Trigger>

                            <!-- Наведение - работает ТОЛЬКО для НЕактивных кнопок -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource MenuHoverButton}"/>
                            </MultiTrigger>

                            <!-- Нормальное состояние - ТОЛЬКО для НЕактивных кнопок, когда курсор не над кнопкой -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource MenuButton}"/>
                            </MultiTrigger>

                            <!-- Состояние нажатия (работает для всех кнопок) -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource MenuButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ГГД -->
            <Button x:Name="GgdPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GgdButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GgdHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GgdButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GgdButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ГРО -->
            <Button x:Name="GroPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GroButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GroHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GroButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource GroButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ТС -->
            <Button x:Name="TcPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TcButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TcHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TcButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TcButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- ЭМ -->
            <Button x:Name="EmPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource EmButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource EmHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource EmButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource EmButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Рецептура -->
            <Button x:Name="ReceptPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource ReceptButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource ReceptHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource ReceptButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource ReceptButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Журнал -->
            <Button x:Name="LogPageButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource LogButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource LogHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource LogButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource LogButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Тренды -->
            <Button x:Name="TrendsButton" 
                    Height="125"
                    Background="Transparent"
                    BorderThickness="0"
                    Tag="Normal">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Image x:Name="contentImage" Width="180" Height="120"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TrendsButtonActive}"/>
                            </Trigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TrendsHoverButton}"/>
                            </MultiTrigger>

                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                    <Condition Property="Tag" Value="Normal"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TrendsButton}"/>
                            </MultiTrigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="contentImage" Property="Source" Value="{StaticResource TrendsButtonActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- BOTTOM PANEL -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FFE3F2FD">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статус доступа (слева) -->
                <TextBlock x:Name="AccessStatusText" 
                           Grid.Column="0"
                           Text="Доступ: отключен" 
                           Foreground="#333"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>

                <!-- Качество связи (справа) -->
                <TextBlock Grid.Column="1" 
                           HorizontalAlignment="Right" 
                           Margin="10,0">
                    <Run Text="Связь с контроллером:" FontWeight="Bold"/>
                    <Run Text=" "/>
                    <Run x:Name="ControllerConnectionQualityLabel" Text="..." FontStyle="Italic"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>