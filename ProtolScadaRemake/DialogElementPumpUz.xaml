<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProtolScadaRemake"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" 
        x:Class="ProtolScadaRemake.DialogElementPumpUz"
        mc:Ignorable="d"
        Title="DialogElementPumpUz" 
        Height="220" 
        Width="682" 
        Background="#FFCCC9C9" 
        FontFamily="Arial" 
        Margin="0,0,0,10"
        Icon="Images/ProtolLogo.ico"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="0,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>
        <GroupBox x:Name="GroupBox1" Header="Режим работы" Margin="10,10,360,-2" Grid.RowSpan="2">
            <StackPanel Height="140">
                <StackPanel Height="46" Margin="0,10,0,0">
                    <RadioButton x:Name="RBAuto" 
                               Content="Автоматический" 
                               Margin="10,0,0,0" 
                               Checked="RBAuto_CheckedChanged"/>
                    <RadioButton x:Name="RBManual" 
                               Content="Ручной" 
                               Margin="10,10,0,0" 
                               Checked="RBManual_CheckedChanged"/>
                </StackPanel>
                <!-- Кнопки с начальной скрытостью -->
                <StackPanel Height="34" Orientation="Horizontal" Margin="0,10,0,0" Width="222">
                    <Button x:Name="StartButton" 
                          Content="Включить" 
                          Width="100" 
                          Visibility="Hidden"
                          Click="StartButton_Click"/>
                    <Button x:Name="StopButton" 
                          Content="Выключить" 
                          Width="100" 
                          Margin="20,0,0,0" 
                          Visibility="Hidden"
                          Click="StopButton_Click"/>
                </StackPanel>
                <!-- Панель ручной скорости с начальной скрытостью -->
                <StackPanel x:Name="ManualSpeed" 
                          Height="30" 
                          Margin="0,10,0,0" 
                          Orientation="Horizontal"
                          Visibility="Hidden">
                    <TextBlock TextWrapping="Wrap" 
                             Text="Ручная скорость: " 
                             Margin="50,0,0,0" 
                             HorizontalAlignment="Center" 
                             VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="ManualSpeedNumeric" 
                                     Width="105" 
                                     Background="White" 
                                     Maximum="100" 
                                     Minimum="0" 
                                     StringFormat="##0"
                                     ValueChanged="ManualSpeedNumeric_ValueChanged"/>
                    <TextBlock TextWrapping="Wrap" 
                             Text="%" 
                             VerticalAlignment="Center" 
                             Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <GroupBox x:Name="GroupBox2" Header="Время выработки насоса" Margin="320,10,0,25">
            <StackPanel Height="84">
                <StackPanel Orientation="Horizontal" Height="39">
                    <TextBlock TextWrapping="Wrap" 
                             Text="Время запуска: " 
                             Width="123" 
                             VerticalAlignment="Center" 
                             Margin="10,0,0,0"/>
                    <mah:NumericUpDown x:Name="StartTimeNumeric" 
                                     Width="155" 
                                     Height="23" 
                                     Background="White" 
                                     Maximum="1000" 
                                     Minimum="0" 
                                     StringFormat="##0" 
                                     ValueChanged="StartTimeNumeric_ValueChanged"/>
                    <TextBlock TextWrapping="Wrap" 
                             Text="сек." 
                             Height="18" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center" 
                             Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Height="39">
                    <TextBlock TextWrapping="Wrap" 
                             Text="Время остановки: " 
                             Width="123" 
                             VerticalAlignment="Center" 
                             Margin="10,0,0,0"/>
                    <mah:NumericUpDown x:Name="StopTimeNumeric" 
                                     Width="155" 
                                     Height="23" 
                                     Background="White" 
                                     StringFormat="##0" 
                                     Maximum="1000" 
                                     Minimum="0" 
                                     ValueChanged="StopTimeNumeric_ValueChanged"/>
                    <TextBlock TextWrapping="Wrap" 
                             Text="сек." 
                             Height="18" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center" 
                             Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>