<UserControl x:Class="ProtolScadaRemake.Element_PumpUz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProtolScadaRemake"
      mc:Ignorable="d" MouseDown="ValueLabel_Click" Height="80">

    <Grid Width="184" Height="80" VerticalAlignment="Center" HorizontalAlignment="Left">
        <Image x:Name ="PumpIcon"  Source="{StaticResource PumpHStopIcon}" Width="60" Height="60" Margin="0,0,0,8" VerticalAlignment="Bottom" HorizontalAlignment="Left"/>
        <Image x:Name="HandImage" HorizontalAlignment="Left" Height="24" Margin="62,3,0,0" VerticalAlignment="Top" Width="20" Source="/Hand.png"/>
        <TextBlock x:Name="TAGNAME" TextWrapping="Wrap" Text="TAG" VerticalAlignment="Top" Width="60" HorizontalAlignment="Left" FontFamily="Arial" Foreground="White" TextAlignment="Center"/>
        <ProgressBar x:Name="SpeedBar" HorizontalAlignment="Left" Height="30" Margin="62,29,0,0" VerticalAlignment="Top" Width="120" BorderBrush="#FF5D5D5D" Background="#FFB4B4B4"/>
        <TextBlock x:Name="SpeedText" HorizontalAlignment="Left" Margin="97,35,0,0" TextWrapping="Wrap" Text="Speed %" VerticalAlignment="Top"/>
    </Grid>
</UserControl>
