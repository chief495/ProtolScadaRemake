<UserControl x:Class="ProtolScadaRemake.Element_DI"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProtolScadaRemake"
             mc:Ignorable="d" 
             Width="90" 
             Height="30"
             MouseDown="ValueLabel_Click">
    <Grid Width="90" Height="30" HorizontalAlignment="Left">
        <Image x:Name ="DIIcon"  Source="{StaticResource DIoffIcon}" Width="30" Height="30" Margin="0,0,20,0" HorizontalAlignment="Left"/>
        <Image x:Name="HandImage" HorizontalAlignment="Left" Height="14" Margin="25,16,0,0" VerticalAlignment="Top" Width="11" Source="/Hand.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="-1"/>
                    <SkewTransform/>
                    <RotateTransform/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <TextBlock x:Name="TagNameTextBlock" HorizontalAlignment="Left" Margin="34,0,0,0" TextWrapping="Wrap" Text="TAG" VerticalAlignment="Center" Height="16" Width="60" FontFamily="Arial" Foreground="White"/>
    </Grid>
</UserControl>
