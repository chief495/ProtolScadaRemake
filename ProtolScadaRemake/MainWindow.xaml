<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ProtolScadaRemake" x:Class="ProtolScadaRemake.MainWindow"
        Title="Система диспетчерского управления технологическим процессом" 
        Height="1080" Width="1920"
        WindowState="Maximized"
        Closing="Window_Closing" WindowStyle="None">

    <Window.Resources>
        <!-- Базовый стиль для кнопок навигации -->
        <Style x:Key="NavigationButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE3F2FD"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFBBDEFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для активной кнопки навигации -->
        <Style x:Key="ActiveNavigationButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource NavigationButtonStyle}">
            <Setter Property="Background" Value="#FFBBDEFB"/>
            <Setter Property="BorderBrush" Value="#FF2196F3"/>
            <Setter Property="BorderThickness" Value="0,0,4,0"/>
        </Style>

        <!-- Стиль для неактивной кнопки навигации -->
        <Style x:Key="InactiveNavigationButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource NavigationButtonStyle}">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <!-- Стиль для текста счетчика аварий -->
        <Style x:Key="FaultCounterTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="17"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="130"/>
        </Grid.ColumnDefinitions>

        <!-- TOP PANEL -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#070142">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="261"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="97"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/ProtolLogo.ico"
                        Width="72" Height="64"/>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="ПРОТОЛ" 
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="БУРОВЗРЫВНЫЕ РАБОТЫ" 
                                   FontWeight="Bold" FontSize="12"
                                   Foreground="White"/>
                    </StackPanel>
                </StackPanel>

                <!-- Title -->
                <TextBlock x:Name="TitleLabel" Grid.Column="1" 
                           Text="ОСНОВНОЙ ЭКРАН" 
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Center" Margin="541,0,0,0"/>

                <!-- Панель счетчика аварий -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/FaultsActive.png" 
                           Width="24" Height="24" Margin="0,0,5,0"/>
                    <Border Background="#FFFF0000" CornerRadius="10" Padding="8,2" Margin="5,0,0,0">
                        <TextBlock x:Name="FaultCounterLabel" 
                                   Text="0" 
                                   Style="{StaticResource FaultCounterTextStyle}"/>
                    </Border>
                </StackPanel>

                <!-- Time -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock x:Name="DateLabel" Text="00.00.0000" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TimeLabel" Text="00:00:00" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Border Grid.Row="1" Grid.Column="0" Background="White">
            <Grid x:Name="ContentGrid" Height="1000">
                <TextBlock Text="Выберите раздел" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="24"
                           Foreground="Gray"/>
            </Grid>
        </Border>

        <!-- RIGHT MENU - БЕЗ MouseEnter/MouseLeave/Click в XAML -->
        <StackPanel Grid.Row="1" Grid.Column="1" Background="#FFE3F2FD">
            <!-- Основной экран -->
            <Button x:Name="MainPageButton" 
                    Height="90" 
                    Style="{StaticResource InactiveNavigationButtonStyle}">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/MainPageActive.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Основной экран" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- ГГД -->
            <Button x:Name="GgdPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/GtdActive.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Подготовка компонентов ГГД" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- ГРО -->
            <Button x:Name="GroPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/GroActive.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Подготовка компонентов ГРО" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- ТС -->
            <Button x:Name="TcPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/ТcActive.png"
                           Width="48" Height="48"/>
                    <TextBlock Text="Подготовка компонентов ТС" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- ЭМ -->
            <Button x:Name="EmPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/EMActve.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Производство ЭМ" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- Рецептура -->
            <Button x:Name="ReceptPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/ReceptActve.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Рецептура" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- Аварии -->
            <Button x:Name="AlarmPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}" Click="AlarmPageButton_Click">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/FaultsActive.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Список аварий" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>

            <!-- Журнал -->
            <Button x:Name="LogPageButton" 
                    Height="96" 
                    Style="{StaticResource InactiveNavigationButtonStyle}" Click="LogPageButton_Click">
                <StackPanel>
                    <Image Source="pack://application:,,,/ProtolScadaRemake;component/Images/TopNavigation/LogActive.png" 
                           Width="48" Height="48"/>
                    <TextBlock Text="Журнал событий" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- BOTTOM PANEL -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#FFE3F2FD">
            <TextBlock HorizontalAlignment="Right" Margin="10,0"><Run Text="Связь с контроллером:" FontWeight="Bold"/><Run Text=" "/><Run x:Name="ControllerConnectionQualityLabel" Text="..." FontStyle="Italic"/></TextBlock>
        </Border>
    </Grid>
</Window>