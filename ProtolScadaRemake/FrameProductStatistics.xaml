<UserControl x:Class="ProtolScadaRemake.FrameProductStatistics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600">

    <Border Background="#FF252526" 
            BorderBrush="#FF007ACC" 
            BorderThickness="2" 
            CornerRadius="10"
            Padding="20">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" 
                       Text="СТАТИСТИКА ПРОИЗВОДСТВА" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Содержимое -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Продукция за смену -->
                <TextBlock Grid.Row="0" Grid.Column="0" 
                           Text="Продукция за смену:" 
                           Margin="10,5"
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="0" Grid.Column="1" 
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBox x:Name="CounterEdit" 
                             Width="200"
                             Height="40"
                             FontSize="18"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             IsReadOnly="True"
                             Background="#FF2D2D30"
                             Foreground="White"
                             BorderBrush="#FF007ACC"
                             BorderThickness="2"
                             Margin="10,5"/>
                    <TextBlock Text="ед." 
                               Margin="10,5"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Row="1" Grid.Column="1" 
                        x:Name="ResetCounterButton"
                        Content="Сбросить счетчик смены"
                        HorizontalAlignment="Left"
                        Click="ResetCounterButton_Click"
                        Width="200"
                        Height="40"
                        FontSize="14"
                        Foreground="White"
                        Background="#FF007ACC"
                        BorderBrush="#FF005A9E"
                        BorderThickness="1"
                        Margin="10,5"
                        Cursor="Hand"/>

                <!-- Вся произведенная продукция -->
                <TextBlock Grid.Row="3" Grid.Column="0" 
                           Text="Вся произведенная продукция:" 
                           Margin="10,5"
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="3" Grid.Column="1" 
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBox x:Name="TotalCounterEdit" 
                             Width="200"
                             Height="40"
                             FontSize="18"
                             FontWeight="Bold"
                             TextAlignment="Center"
                             VerticalContentAlignment="Center"
                             IsReadOnly="True"
                             Background="#FF2D2D30"
                             Foreground="White"
                             BorderBrush="#FF007ACC"
                             BorderThickness="2"
                             Margin="10,5"/>
                    <TextBlock Text="ед." 
                               Margin="10,5"
                               Foreground="White"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Button Grid.Row="4" Grid.Column="1" 
                        x:Name="ResetTotalCounterButton"
                        Content="Сбросить общий счетчик"
                        HorizontalAlignment="Left"
                        Click="ResetTotalCounterButton_Click"
                        Width="200"
                        Height="40"
                        FontSize="14"
                        Foreground="White"
                        Background="#FF007ACC"
                        BorderBrush="#FF005A9E"
                        BorderThickness="1"
                        Margin="10,5"
                        Cursor="Hand"/>
            </Grid>

            <!-- Статус -->
            <Border Grid.Row="2" 
                    Background="#FF007ACC" 
                    CornerRadius="5"
                    Margin="0,20,0,0"
                    Padding="10,5">
                <TextBlock x:Name="StatusText"
                           Text="Статус: Активно"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           FontSize="14"/>
            </Border>
        </Grid>
    </Border>
</UserControl>