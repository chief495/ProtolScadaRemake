<UserControl x:Class="ProtolScadaRemake.FrameGroPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProtolScadaRemake"
             xmlns:ImageXaml="clr-namespace:ProtolScadaRemake.ImageXaml"
             mc:Ignorable="d" 
             d:DesignHeight="1010" d:DesignWidth="1790"
             Loaded="UserControl_Loaded">

    <Grid Width="1790" Height="1010">
        <!-- Фоновая картинка -->
        <ImageXaml:ImageGroPage HorizontalAlignment="Center" VerticalAlignment="Top" Width="1790" Height="1010"/>

        <!-- Основной контейнер -->
        <Canvas x:Name="MainCanvas" Width="1790" Height="1010">

            <!-- Датчики уровня (AI) -->
            <local:Element_AI x:Name="LT150" Canvas.Left="1135" Canvas.Top="869"/>
            <local:Element_AI x:Name="LT301" Canvas.Left="970" Canvas.Top="306"/>
            <local:Element_AI x:Name="LT303" Canvas.Left="1225" Canvas.Top="300"/>
            <local:Element_AI x:Name="LT403" Canvas.Left="399" Canvas.Top="340"/>

            <!-- Сигнализаторы уровня (DI) -->
            <local:Element_DI x:Name="LAHH101" Canvas.Left="127" Canvas.Top="773" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <local:Element_DI x:Name="LALL103" Canvas.Left="127" Canvas.Top="813" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <local:Element_DI x:Name="LAHH151" Canvas.Left="955" Canvas.Top="788"/>
            <local:Element_DI x:Name="LALL153" Canvas.Left="955" Canvas.Top="886" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <local:Element_DI x:Name="LAHH301" Canvas.Left="881" Canvas.Top="231"/>
            <local:Element_DI x:Name="LAHH302" Canvas.Left="1135" Canvas.Top="231" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <local:Element_DI x:Name="LAHH401" Canvas.Left="216" Canvas.Top="261"/>

            <!-- Датчики температуры (AI) -->
            <local:Element_AI x:Name="TT102" Canvas.Left="309" Canvas.Top="777"/>
            <local:Element_AI x:Name="TT106" Canvas.Left="806" Canvas.Top="829"/>
            <local:Element_AI x:Name="TT152" Canvas.Left="1135" Canvas.Top="795" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <local:Element_AI x:Name="TT302" Canvas.Left="1225" Canvas.Top="234"/>
            <local:Element_AI x:Name="TT402" Canvas.Left="399" Canvas.Top="264"/>
            <local:Element_AI x:Name="TT602" Canvas.Left="1399" Canvas.Top="620"/>

            <!-- Датчики давления (AI) -->
            <local:Element_AI x:Name="PT104" Canvas.Left="463" Canvas.Top="813" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <local:Element_AI x:Name="PT105" Canvas.Left="806" Canvas.Top="854" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <local:Element_AI x:Name="PT304" Canvas.Left="620" Canvas.Top="368" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <local:Element_AI x:Name="PT404" Canvas.Left="127" Canvas.Top="444" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <local:Element_AI x:Name="PT601" Canvas.Left="1399" Canvas.Top="672"/>

            <!-- Расходомеры (AI) -->
            <local:Element_AI x:Name="FM401" Canvas.Left="127" Canvas.Top="505"/>
            <local:Element_AI x:Name="FM601" Canvas.Left="1399" Canvas.Top="794"/>

            <!-- Счетчик QM400 (AI) -->
            <local:Element_AI x:Name="QM400" Canvas.Left="636" Canvas.Top="166" HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <!-- Весовой датчик WIT100 (AI) -->
            <local:Element_AI x:Name="WIT100" Canvas.Left="200" Canvas.Top="924" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <!-- Миксеры (переключатели) -->
            <StackPanel Canvas.Left="306" Canvas.Top="647" Width="70" Height="80">
                <TextBlock Text="M100" 
                          Foreground="White" 
                          FontSize="12" 
                          HorizontalAlignment="Center"
                          Margin="0,0,0,5"/>
                <local:ToggleSwitch x:Name="M100Switch" 
                                   Width="50" 
                                   Height="25"
                                   StateChanged="M100Switch_StateChanged"/>
            </StackPanel>

            <StackPanel Canvas.Left="886" Canvas.Top="692" Width="70" Height="80">
                <TextBlock Text="M150" 
                          Foreground="White" 
                          FontSize="12" 
                          HorizontalAlignment="Center"
                          Margin="0,0,0,5"/>
                <local:ToggleSwitch x:Name="M150Switch" 
                                   Width="50" 
                                   Height="25"
                                   StateChanged="M150Switch_StateChanged"/>
            </StackPanel>

            <StackPanel Canvas.Left="399" Canvas.Top="420" Width="70" Height="80">
                <TextBlock Text="M400" 
                          Foreground="White" 
                          FontSize="12" 
                          HorizontalAlignment="Center"
                          Margin="0,0,0,5"/>
                <local:ToggleSwitch x:Name="M400Switch" 
                                   Width="50" 
                                   Height="25"
                                   StateChanged="M400Switch_StateChanged"/>
            </StackPanel>

            <!-- Насосы обратные (P300, P400) -->
            <local:Element_PumpHReverse x:Name="P300" Canvas.Left="1527" Canvas.Top="208"/>
            <local:Element_PumpHReverse x:Name="P400" Canvas.Left="126" Canvas.Top="340"/>

            <!-- Насосы обычные -->
            <local:Element_PumpUzUnderPanel x:Name="P100" Canvas.Left="550" Canvas.Top="844"/>
            <local:Element_PumpUzUnderPanel x:Name="A100" Canvas.Left="35" Canvas.Top="566"/>
            <local:Element_PumpUzUnderPanel x:Name="P601" Canvas.Left="1298" Canvas.Top="837"/>

            <!-- Задвижки горизонтальные -->
            <local:Element_ValveV x:Name="VT101" Canvas.Left="208" Canvas.Top="646"/>
            <local:Element_ValveH x:Name="VT151" Canvas.Left="886" Canvas.Top="625"/>
            <local:Element_ValveH x:Name="VT152" Canvas.Left="645" Canvas.Top="420"/>
            <local:Element_ValveV x:Name="VT302" Canvas.Left="1206" Canvas.Top="132" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <local:Element_ValveV x:Name="VT305" Canvas.Left="375" Canvas.Top="545"/>
            <local:Element_ValveV x:Name="VT401" Canvas.Left="460" Canvas.Top="134"/>

            <!-- 3-ходовой клапан -->
            <local:Element_3ValveH x:Name="VT601" Canvas.Left="1513" Canvas.Top="542"/>

            <!-- Нагреватели -->
            <local:Element_Heater x:Name="HE300" Canvas.Left="1390" Canvas.Top="258"/>
            <local:Element_Heater x:Name="HE750" Canvas.Left="1292" Canvas.Top="773"/>
            <local:Element_Heater x:Name="HE700_1" Canvas.Left="676" Canvas.Top="725"/>
            <local:Element_Heater x:Name="HE700_2" Canvas.Left="766" Canvas.Top="725"/>

            <!-- Панель выбора режима (левый верхний угол) -->
            <local:ModePanel x:Name="GroModePanel"
                            Canvas.Left="20"
                            Canvas.Top="20"
                            Width="180"
                            Height="200"
                            ModeChanged="GroModePanel_ModeChanged"/>

            <!-- Панель задания массы в Т-100 -->
            <Border Canvas.Left="676" 
                   Canvas.Top="218" 
                   Width="180" 
                   Height="140"
                   BorderBrush="#666666" 
                   BorderThickness="1"
                   Background="Transparent"
                   CornerRadius="8"
                   Padding="15" HorizontalAlignment="Center" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="МАССА Т-100"
                               FontWeight="Heavy"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <Border Height="28" 
                           CornerRadius="5" 
                           Background="#444444"
                           BorderBrush="#666666"
                           BorderThickness="1"
                           Margin="0,0,0,10">
                        <TextBox x:Name="T100MassSpEdit" 
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                FontSize="14"
                                Text="0"
                                VerticalContentAlignment="Center"
                                Padding="5,0"/>
                    </Border>

                    <Button x:Name="SetT100MassButton" 
                            Content="ЗАДАТЬ"
                            Height="28"
                            FontWeight="Bold"
                            FontSize="14"
                            Foreground="White"
                            Background="#267ABB"
                            BorderThickness="0"
                            Click="SetT100MassButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Панель выбора вещества с уставками и счетчиками -->
            <Border x:Name="SubstancePanel" 
                   Canvas.Left="10" 
                   Canvas.Top="240" 
                   Width="200" 
                   Height="400"
                   BorderBrush="#666666" 
                   BorderThickness="1"
                   Background="Transparent"
                   CornerRadius="8"
                   Padding="15">
                <StackPanel>
                    <TextBlock Text="ВЕЩЕСТВО"
                               FontWeight="Heavy"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <!-- Выбор вещества -->
                    <StackPanel Margin="0,0,0,10">
                        <RadioButton x:Name="SelitraRadio" 
                                    Content="СЕЛИТРА"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Margin="0,5"/>
                        <RadioButton x:Name="WaterRadio" 
                                    Content="ВОДА"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Margin="0,5"/>
                        <RadioButton x:Name="KislotaRadio" 
                                    Content="КИСЛОТА"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="14"
                                    Margin="0,5"/>
                    </StackPanel>

                    <!-- Уставки -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Уставка (кг):" 
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Селитра:" 
                                       Foreground="White"
                                       FontSize="11"
                                       Width="60"
                                       VerticalAlignment="Center"/>
                            <Border Height="24" 
                                   Width="70"
                                   CornerRadius="5" 
                                   Background="#444444"
                                   BorderBrush="#666666"
                                   BorderThickness="1">
                                <TextBox x:Name="SelitraSpEdit" 
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="11"
                                        Text="0"
                                        VerticalContentAlignment="Center"
                                        Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Вода:" 
                                       Foreground="White"
                                       FontSize="11"
                                       Width="60"
                                       VerticalAlignment="Center"/>
                            <Border Height="24" 
                                   Width="70"
                                   CornerRadius="5" 
                                   Background="#444444"
                                   BorderBrush="#666666"
                                   BorderThickness="1">
                                <TextBox x:Name="WaterSpEdit" 
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="11"
                                        Text="0"
                                        VerticalContentAlignment="Center"
                                        Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Кислота:" 
                                       Foreground="White"
                                       FontSize="11"
                                       Width="60"
                                       VerticalAlignment="Center"/>
                            <Border Height="24" 
                                   Width="70"
                                   CornerRadius="5" 
                                   Background="#444444"
                                   BorderBrush="#666666"
                                   BorderThickness="1">
                                <TextBox x:Name="KislotaSpEdit" 
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="11"
                                        Text="0"
                                        VerticalContentAlignment="Center"
                                        Padding="5,0"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Счетчики -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Счетчики:" 
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="Селитра:" 
                                       Foreground="White"
                                       FontSize="11"
                                       Width="60"
                                       VerticalAlignment="Center"/>
                            <Border Height="24" 
                                   Width="70"
                                   CornerRadius="5" 
                                   Background="#333333"
                                   BorderBrush="#666666"
                                   BorderThickness="1">
                                <TextBox x:Name="GRO_ManualSelitraCounterEdit" 
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="11"
                                        IsReadOnly="True"
                                        Text="0"
                                        VerticalContentAlignment="Center"
                                        Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="Вода:" 
                                       Foreground="White"
                                       FontSize="11"
                                       Width="60"
                                       VerticalAlignment="Center"/>
                            <Border Height="24" 
                                   Width="70"
                                   CornerRadius="5" 
                                   Background="#333333"
                                   BorderBrush="#666666"
                                   BorderThickness="1">
                                <TextBox x:Name="GRO_ManualWaterCounterEdit" 
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="11"
                                        IsReadOnly="True"
                                        Text="0"
                                        VerticalContentAlignment="Center"
                                        Padding="5,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                            <TextBlock Text="Кислота:" 
                                       Foreground="White"
                                       FontSize="11"
                                       Width="60"
                                       VerticalAlignment="Center"/>
                            <Border Height="24" 
                                   Width="70"
                                   CornerRadius="5" 
                                   Background="#333333"
                                   BorderBrush="#666666"
                                   BorderThickness="1">
                                <TextBox x:Name="GRO_ManualKislotaCounterEdit" 
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="White"
                                        FontSize="11"
                                        IsReadOnly="True"
                                        Text="0"
                                        VerticalContentAlignment="Center"
                                        Padding="5,0"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Кнопки управления -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="0,10,0,0">
                        <Button x:Name="SubstanceStartButton" 
                                Content="ПУСК"
                                Width="70"
                                Height="28"
                                FontWeight="Bold"
                                FontSize="12"
                                Foreground="White"
                                Background="#267ABB"
                                BorderThickness="0"
                                Click="SubstanceStartButton_Click"/>
                        <Button x:Name="SubstanceStopButton" 
                                Content="СТОП"
                                Width="70"
                                Height="28"
                                FontWeight="Bold"
                                FontSize="12"
                                Foreground="White"
                                Background="#267ABB"
                                BorderThickness="0"
                                Margin="5,0"
                                Click="SubstanceStopButton_Click"/>
                        <Button x:Name="SubstancePauseButton" 
                                Content="ПАУЗА"
                                Width="70"
                                Height="28"
                                FontWeight="Bold"
                                FontSize="12"
                                Foreground="White"
                                Background="#FF9900"
                                BorderThickness="0"
                                Margin="5,0"
                                Click="SubstancePauseButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Панель перекачки -->
            <Border x:Name="TransportPanel" 
                   Canvas.Left="445" 
                   Canvas.Top="681" 
                   Width="180" 
                   Height="120"
                   BorderBrush="#666666" 
                   BorderThickness="1"
                   Background="Transparent"
                   CornerRadius="8"
                   Padding="15"
                   Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="ПЕРЕКАЧКА"
                               FontWeight="Heavy"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center">
                        <Button x:Name="TransportStartButton" 
                                Content="ПУСК"
                                Width="70"
                                Height="28"
                                FontWeight="Bold"
                                FontSize="12"
                                Foreground="White"
                                Background="#267ABB"
                                BorderThickness="0"
                                Click="TransportStartButton_Click"/>
                        <Button x:Name="TransportStopButton" 
                                Content="СТОП"
                                Width="70"
                                Height="28"
                                FontWeight="Bold"
                                FontSize="12"
                                Foreground="White"
                                Background="#267ABB"
                                BorderThickness="0"
                                Margin="10,0,0,0"
                                Click="TransportStopButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Панель скорости A100 (уменьшенная) -->
            <Border Canvas.Left="10" 
                   Canvas.Top="660" 
                   Width="180" 
                   Height="100"
                   BorderBrush="#666666" 
                   BorderThickness="1"
                   Background="Transparent"
                   CornerRadius="8"
                   Padding="15">
                <StackPanel>
                    <TextBlock Text="СКОРОСТЬ A100"
                               FontWeight="Heavy"
                               FontSize="14"
                               Foreground="White"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Height="28" 
                               Width="60"
                               CornerRadius="5" 
                               Background="#444444"
                               BorderBrush="#666666"
                               BorderThickness="1"
                               Margin="0,0,5,0">
                            <TextBox x:Name="A100SpeedSpEdit" 
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    FontSize="12"
                                    Text="0"
                                    VerticalContentAlignment="Center"
                                    Padding="5,0"
                                    TextChanged="A100SpeedSpEdit_TextChanged"/>
                        </Border>
                        <TextBlock Text="%"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Панель режима HE-700 -->
            <Border Canvas.Left="646" 
                   Canvas.Top="525" 
                   Width="180" 
                   Height="140"
                   BorderBrush="#666666" 
                   BorderThickness="1"
                   Background="Transparent"
                   CornerRadius="8"
                   Padding="15">
                <StackPanel>
                    <TextBlock Text="HE-700 РЕЖИМ"
                               FontWeight="Heavy"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <ComboBox x:Name="HE700ComboBox" 
                             Height="28"
                             FontSize="14"
                             Margin="0,0,0,10">
                        <ComboBoxItem Content="Только HE-700.1"/>
                        <ComboBoxItem Content="Только HE-700.2"/>
                        <ComboBoxItem Content="HE-700.1 => HE700.2"/>
                        <ComboBoxItem Content="HE-700.2 => HE700.1"/>
                    </ComboBox>

                    <Button x:Name="SaveHE700RejimButton" 
                            Content="СОХРАНИТЬ"
                            Height="28"
                            FontWeight="Bold"
                            FontSize="14"
                            Foreground="White"
                            Background="#267ABB"
                            BorderThickness="0"
                            Click="SaveHE700RejimButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Индикаторы счетчиков -->
            <Border Canvas.Left="900" 
                   Canvas.Top="50" 
                   Width="200" 
                   Height="140"
                   BorderBrush="#666666" 
                   BorderThickness="1"
                   Background="Transparent"
                   CornerRadius="8"
                   Padding="15">
                <StackPanel>
                    <TextBlock Text="СЧЕТЧИКИ"
                               FontWeight="Heavy"
                               FontSize="16"
                               Foreground="White"
                               Margin="0,0,0,10"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>

                    <TextBlock x:Name="SelitraCounterText" 
                              Text="Селитра: 0 кг" 
                              Foreground="White" 
                              FontSize="12" 
                              Margin="0,2"/>

                    <TextBlock x:Name="WaterCounterText" 
                              Text="Вода: 0 кг" 
                              Foreground="White" 
                              FontSize="12" 
                              Margin="0,2"/>

                    <TextBlock x:Name="KislotaCounterText" 
                              Text="Кислота: 0 кг" 
                              Foreground="White" 
                              FontSize="12" 
                              Margin="0,2"/>
                </StackPanel>
            </Border>

        </Canvas>
    </Grid>
</UserControl>