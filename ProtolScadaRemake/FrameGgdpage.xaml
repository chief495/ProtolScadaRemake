<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProtolScadaRemake"
             xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"            
             xmlns:ImageXaml="clr-namespace:ProtolScadaRemake.ImageXaml" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
             x:Class="ProtolScadaRemake.FrameGgdPage"            
             mc:Ignorable="d" 
             Width="1790" 
             Height="1010" 
             Margin="0,0,0,0">

    <Grid Width="1790" Height="1020" VerticalAlignment="Bottom" HorizontalAlignment="Left">
        <!-- Фоновая картинка -->
        <ImageXaml:ImageGgdPage HorizontalAlignment="Center" VerticalAlignment="Top" Width="1790" Height="1020" Margin="0,0,0,0"/>

        <!-- Панель набора воды T500 (левая сторона) -->
        <local:WaterFillPanel x:Name="T500WaterPanel"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom"
                              Margin="413,0,0,71"
                              Width="250"
                              Height="157"
                              TankName="T-500"
                              StartButtonClick="T500WaterPanel_StartButtonClick"
                              StopButtonClick="T500WaterPanel_StopButtonClick"/>

        <!-- Панель набора воды T400 (правая сторона) -->
        <local:WaterFillPanel x:Name="T400WaterPanel"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,594,71"
                              Width="250"
                              Height="157"
                              TankName="T-400"
                              StartButtonClick="T400WaterPanel_StartButtonClick"
                              StopButtonClick="T400WaterPanel_StopButtonClick"/>

        <!-- ========== АНАЛОГОВЫЕ ДАТЧИКИ T-400 ========== -->
        <!-- TT402 - Температура T400 -->
        <local:Element_AI x:Name="TT402"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top" 
                          Margin="1071,472,0,0"/>

        <!-- LT403 - Уровень T400 -->
        <local:Element_AI x:Name="LT403"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top" 
                          Margin="1071,542,0,0"/>

        <!-- PT404 - Давление T400 -->
        <local:Element_AI x:Name="PT404"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top" 
                          Margin="1367,508,0,0"/>

        <!-- ========== АНАЛОГОВЫЕ ДАТЧИКИ T-500 ========== -->
        <!-- TT502 - Температура T500 -->
        <local:Element_AI x:Name="TT502"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top" 
                          Margin="0,472,1069,0"/>

        <!-- LT503 - Уровень T500 -->
        <local:Element_AI x:Name="LT503"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top" 
                          Margin="0,542,1069,0"/>

        <!-- PT504 - Давление T500 -->
        <local:Element_AI x:Name="PT504"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top" 
                          Margin="0,514,1505,0"/>

        <!-- ========== ДИСКРЕТНЫЕ ДАТЧИКИ T-400 ========== -->
        <!-- LAHH401 - Аварийный уровень T400 -->
        <local:Element_DI x:Name="LAHH401"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top" 
                          Margin="895,472,0,0"/>

        <!-- ========== ДИСКРЕТНЫЕ ДАТЧИКИ T-500 ========== -->
        <!-- LAHH501 - Аварийный уровень T500 -->
        <local:Element_DI x:Name="LAHH501"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top" 
                          Margin="0,472,1287,0"/>

        <!-- ========== КЛАПАНЫ ========== -->
        <!-- VT401 - Клапан V-401 -->
        <local:Element_ValveV x:Name="VT401"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top" 
                              Margin="1091,319,0,0"/>

        <!-- VT501 - Клапан V-501 -->
        <local:Element_ValveV x:Name="VT501"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top" 
                              Margin="0,319,1127,0"/>

        <!-- ========== НАСОСЫ ========== -->
        <!-- P400 - Насос P-400 (Element_PumpUz) -->
        <local:Element_PumpUz x:Name="P400"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom" 
                             Margin="1243,0,0,411"/>

        <!-- P500 - Насос P-500 (Element_PumpH) -->
        <local:Element_PumpHReverse x:Name="P500"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Bottom" 
                             Margin="0,0,1398,419"/>

        <!-- ========== ДРУГИЕ ЭЛЕМЕНТЫ ========== -->
        <!-- FM401 - Расходомер -->
        <local:Element_AI x:Name="FM401"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top" 
                          Margin="1427,596,0,0"/>

        <!-- ========== ПЕРЕКЛЮЧАТЕЛИ МИКСЕРОВ ========== -->
        <!-- T400 Mixer Toggle -->
        <local:ToggleSwitch x:Name="T400MixerToggle"
                            Width="60"
                            Height="30"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top" 
                            Margin="1015,433,0,0"/>

        <!-- T500 Mixer Toggle -->
        <local:ToggleSwitch x:Name="T500MixerToggle"
                            Width="60"
                            Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top" 
                            Margin="0,433,1204,0"/>

        <!-- ========== СЧЕТЧИКИ (как Element_AI) ========== -->
        <!-- QM-400 Счетчик -->
        <local:Element_AI x:Name="QM400Counter"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top" 
                          Margin="1139,210,0,0"/>

        <!-- QM-500 Счетчик -->
        <local:Element_AI x:Name="QM500Counter"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Top" 
                          Margin="0,210,1001,0"/>

    </Grid>
</UserControl>