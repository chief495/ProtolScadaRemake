<!-- FrameLog.xaml -->
<UserControl x:Class="ProtolScadaRemake.Views.FrameLog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProtolScadaRemake.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель инструментов -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
            <Button x:Name="btnRefresh" Content="Обновить" Margin="5,0" Click="BtnRefresh_Click"/>
            <Button x:Name="btnClear" Content="Очистить" Margin="5,0" Click="BtnClear_Click"/>
            <Button x:Name="btnExport" Content="Экспорт..." Margin="5,0" Click="BtnExport_Click"/>

            <Separator Margin="10,0" Width="2"/>

            <TextBlock Text="Фильтр:" VerticalAlignment="Center" Margin="5,0"/>
            <ComboBox x:Name="cmbFilter" Width="150" Margin="5,0" SelectionChanged="CmbFilter_SelectionChanged"/>

            <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="txtFilterGroup" Width="120" Margin="5,0" TextChanged="TxtFilterGroup_TextChanged"/>
        </StackPanel>

        <!-- Список журнала -->
        <ListView x:Name="lvLog" Grid.Row="1" ItemsSource="{Binding LogItems}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Время" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Time, StringFormat='dd.MM.yyyy HH:mm:ss'}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Группа" Width="100" DisplayMemberBinding="{Binding GroupName}"/>
                    <GridViewColumn Header="Сообщение" Width="400" DisplayMemberBinding="{Binding Text}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="tbStatus" Text="Записей: 0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding ElementName=lvLog, Path=Items.Count, StringFormat='Всего: {0}'}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</UserControl>