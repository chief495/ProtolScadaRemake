<Window x:Class="ProtolScadaRemake.DialogElementQM"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="DialogElementQM"
        Height="220"
        Width="650"
        Background="#FFCCC9C9"
        Icon="/Images/ProtolLogo.ico"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: Счётчик -->
        <GroupBox Header="Счётчик" FontFamily="Arial" FontSize="12" Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Label Content="Текущее значение:" Width="140" Padding="0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TotalLabel" 
                               Width="70" 
                               TextAlignment="Right" 
                               VerticalAlignment="Center"
                               FontWeight="Bold"/>
                    <Label x:Name="CurrentValueEU" Width="40" Padding="4,0,0,0" Content="л"/>
                </StackPanel>

                <Button x:Name="ResetButton"
                        Content="Сброс счётчика"
                        Height="30"
                        Width="170"
                        HorizontalAlignment="Left"
                        Click="ResetButton_Click"/>
            </StackPanel>
        </GroupBox>

        <!-- Правая колонка: Настройки -->
        <GroupBox x:Name="SettingsGroupBox"
                  Grid.Column="1"
                  Header="Настройки"
                  FontFamily="Arial"
                  FontSize="12"
                  Padding="10"
                  Margin="10,0,0,0">
            <StackPanel>
                <!-- Начальное значение -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Начальное значение:" Padding="0" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="StartValueNumeric"
                                       Grid.Column="1"
                                       Minimum="0"
                                       Maximum="1000000"
                                       NumericInputMode="Numbers"
                                       ValueChanged="StartValueNumeric_ValueChanged"/>
                    <Label Grid.Column="2" Content="л" Padding="5,0,0,0" VerticalAlignment="Center"/>
                </Grid>

                <!-- Импульсов на м³ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Импульсов на м³:" Padding="0" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="PulseInCubeNumeric"
                                       Grid.Column="1"
                                       Minimum="0"
                                       Maximum="1000000"
                                       NumericInputMode="Numbers"
                                       ValueChanged="PulseInCubeNumeric_ValueChanged"/>
                </Grid>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>