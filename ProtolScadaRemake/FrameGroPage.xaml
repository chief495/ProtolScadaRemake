                                FontSize="10"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="TransportStartButton_Click"/>
                    </Border>
                    <Border Background="#7B001C"
                            BorderBrush="#FF0033"
                            BorderThickness="1"
                            CornerRadius="6"
                            Width="70" 
                            Height="22">
                        <Button x:Name="TransportStopButton" 
                                Content="СТОП"
                                Foreground="White"
                                FontSize="10"
                                FontWeight="Bold"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="TransportStopButton_Click"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель скорости A100 -->
        <Border x:Name="A100SpeedPanel" 
               Visibility="Collapsed"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="10,645,0,0" 
               Width="180" 
               Height="100"
               BorderBrush="#666666" 
               BorderThickness="1"
               Background="Transparent"
               CornerRadius="8"
               Padding="15">
            <StackPanel>
                <TextBlock Text="СКОРОСТЬ A100"
                           FontWeight="Heavy"
                           FontSize="14"
                           Foreground="White"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Height="28" 
                           Width="60"
                           CornerRadius="5" 
                           Background="#444444"
                           BorderBrush="#666666"
                           BorderThickness="1"
                           Margin="0,0,5,0">
                        <TextBox x:Name="A100SpeedSpEdit" 
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                FontSize="12"
                                Text="0"
                                VerticalContentAlignment="Center"
                                Padding="5,0"
                                TextChanged="A100SpeedSpEdit_TextChanged"/>
                    </Border>
                    <TextBlock Text="%"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Панель режима HE-700 -->
        <Border x:Name="HE700Panel" 
               Visibility="Collapsed"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               Margin="762,527,0,0" 
               Width="180" 
               Height="140"
               BorderBrush="#666666" 
               BorderThickness="1"
               Background="Transparent"
               CornerRadius="8"
               Padding="15">
            <StackPanel>
                <TextBlock Text="HE-700 РЕЖИМ"
                           FontWeight="Heavy"
                           FontSize="16"
                           Foreground="White"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <ComboBox x:Name="HE700ComboBox" 
                         Height="28"
                         FontSize="14"
                         Margin="0,0,0,10">
                    <ComboBoxItem Content="Только HE-700.1"/>
                    <ComboBoxItem Content="Только HE-700.2"/>
                    <ComboBoxItem Content="HE-700.1 => HE700.2"/>
                    <ComboBoxItem Content="HE-700.2 => HE700.1"/>
                </ComboBox>
                <Border Background="#FF1E5945"
                        BorderBrush="#FF00FF00"
                        BorderThickness="1"
                        CornerRadius="8"
                        Height="28">
                    <Button x:Name="SaveHE700RejimButton" 
                            Content="СОХРАНИТЬ"
                            FontWeight="Bold"
                            FontSize="14"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="SaveHE700RejimButton_Click"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
