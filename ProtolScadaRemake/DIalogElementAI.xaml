<Window x:Class="ProtolScadaRemake.DialogElementAI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProtolScadaRemake"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls" 
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="DialogElementAI" 
        Height="360" 
        Width="650" 
        Background="#FFCCC9C9" 
        Icon="Images/ProtolLogo.ico"
        SizeToContent="Manual"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True">

    <Grid Background="#FFCCC9C9" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая колонка: Режим работы -->
        <GroupBox x:Name="GroupBox1" 
                  Header="Режим работы" 
                  FontFamily="Arial" 
                  FontSize="12"
                  Padding="10">
            <StackPanel>
                <RadioButton x:Name="RBAuto" 
                           Content="Автоматический" 
                           Margin="0,5,0,10" 
                           FontSize="11"
                           Checked="RBAuto_Checked"/>

                <RadioButton x:Name="RBManual" 
                           Content="Ручной" 
                           Margin="0,0,0,15" 
                           FontSize="11"
                           Checked="RBManual_Checked"/>

                <!-- Панель ручного значения - БЕЗ Visibility, управляется из кода -->
                <StackPanel Orientation="Horizontal" 
                          VerticalAlignment="Center"
                          Margin="0,5,0,0">
                    <Label x:Name="ManualValueTitle" 
                         Content="Ручное значение:" 
                         FontSize="11"
                         Width="120"
                         Padding="0"
                         Visibility="Hidden"/>

                    <mah:NumericUpDown x:Name="ManualValueNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" 
                                     Background="White" 
                                     Minimum="0" 
                                     Maximum="100" 
                                     Width="80"
                                     FontSize="11"
                                     Margin="5,0,0,0"
                                     Visibility="Hidden"
                                     ValueChanged="ManualValueNumeric_ValueChanged"/>

                    <Label x:Name="ManualValueUnits" 
                         FontFamily="Arial" 
                         FontSize="11"
                         Margin="5,0,0,0"
                         VerticalAlignment="Center"
                         Padding="0"
                         Visibility="Hidden"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Правая колонка: Аварийные и предаварийные значения -->
        <GroupBox x:Name="GroupBox2" 
                  Grid.Column="1" 
                  Header="Аварийные и предаварийные значения" 
                  FontFamily="Arial"
                  FontSize="12"
                  Padding="10"
                  Margin="10,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Width="180">
                    <Label Content="Верхнее аварийное значение:" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label Content="Верхнее предаварийное значение:" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label Content="Нижнее предаварийное значение:" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label Content="Нижнее аварийное значение:" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Width="100" Margin="5,0,0,0">
                    <mah:NumericUpDown x:Name="HFNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontFamily="Arial" FontSize="10" Width="100" Background="White" Maximum="100" Minimum="0" ValueChanged="HFNumeric_ValueChanged"/>
                    <mah:NumericUpDown x:Name="HWNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="100" Minimum="0" ValueChanged="HWNumeric_ValueChanged"/>
                    <mah:NumericUpDown x:Name="LWNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="100" Minimum="0" ValueChanged="LWNumeric_ValueChanged"/>
                    <mah:NumericUpDown x:Name="LFNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="100" Minimum="0" ValueChanged="LFNumeric_ValueChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Width="40" Margin="5,0,0,0">
                    <Label x:Name="TextEU1" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label x:Name="TextEU2" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label x:Name="TextEU3" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label x:Name="TextEU4" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Нижняя часть: Параметры нормирования -->
        <GroupBox x:Name="GroupBox3" 
                  Header="Параметры нормирования" 
                  Grid.Row="1" 
                  Grid.ColumnSpan="2"
                  FontFamily="Arial"
                  FontSize="12"
                  Padding="10"
                  Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Width="220">
                    <TextBlock Text="Нижняя граница измеряемого уровня:" FontSize="10" Height="28" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Верхняя граница измеряемого уровня:" FontSize="10" Height="28" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Нижняя граница токовой петли:" FontSize="10" Height="28" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Верхняя граница токовой петли:" FontSize="10" Height="28" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Width="100" Margin="10,0,0,0">
                    <mah:NumericUpDown x:Name="LowLevelNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="100" Minimum="0" ValueChanged="LowLevelNumeric_ValueChanged"/>
                    <mah:NumericUpDown x:Name="HiLevelNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="100" Minimum="0" ValueChanged="HiLevelNumeric_ValueChanged"/>
                    <mah:NumericUpDown x:Name="LowCurrNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="30" Minimum="0" ValueChanged="LowCurrNumeric_ValueChanged"/>
                    <mah:NumericUpDown x:Name="HiCurrNumeric" UpDownButtonsWidth="30" HideUpDownButtons="False" Foreground="Black" Height="28" FontSize="10" Background="White" Maximum="30" Minimum="0" ValueChanged="HiCurrNumeric_ValueChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Width="50" Margin="10,0,0,0">
                    <Label x:Name="TextEU5" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label x:Name="TextEU6" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label Content="мА" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                    <Label Content="мА" FontFamily="Arial" FontSize="10" Height="28" Padding="0,5"/>
                </StackPanel>
            </Grid>
        </GroupBox>
    </Grid>
</Window>