<UserControl x:Class="ProtolScadaRemake.Element_Heater"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProtolScadaRemake"
             mc:Ignorable="d" Height="80" Width="80" MouseDown="ValueLabel_Click">
    
        <Grid Width="80" Height="80">
            <Image x:Name ="HeaterIcon"  Source="{StaticResource HeaterOffIcon}" Width="62" Height="80" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Image x:Name="HandImage" HorizontalAlignment="Left" Height="24" VerticalAlignment="Top" Width="20" Source="/Hand.png" Margin="63,53,0,0"/>
    </Grid>
    
</UserControl>
