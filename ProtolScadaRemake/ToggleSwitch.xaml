<UserControl x:Class="ProtolScadaRemake.ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Name="ToggleControl"
             Height="25" 
             Width="50"
             Background="Transparent">

    <UserControl.Resources>
        <Storyboard x:Key="TurnOnAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.X)"
                                           Storyboard.TargetName="SwitchThumb">
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="25">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="TurnOffAnimation">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(TranslateTransform.X)"
                                           Storyboard.TargetName="SwitchThumb">
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Внешний контур -->
        <Border CornerRadius="12.5"
                Width="50"
                Height="25"
                Background="#E0E0E0"
                Margin="0,0,0,0.5">
            <Border.Effect>
                <DropShadowEffect BlurRadius="1.5" ShadowDepth="1" Color="#40000000"/>
            </Border.Effect>
        </Border>

        <!-- Основной переключатель -->
        <Border x:Name="MainBorder"
                CornerRadius="12.5"
                Width="50"
                Height="25"
                Cursor="Hand"
                MouseLeftButtonDown="ToggleSwitch_MouseLeftButtonDown">

            <!-- Фон переключателя -->
            <Border x:Name="BackgroundBorder"
                    CornerRadius="12.5">

                <Grid>
                    <!-- Круглый переключатель -->
                    <Border x:Name="SwitchThumb"
                            Width="19"
                            Height="19"
                            CornerRadius="9.5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="2,0,0,0"
                            Background="White">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <TranslateTransform X="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="1.5" 
                                              ShadowDepth="1" 
                                              Color="#40000000"/>
                        </Border.Effect>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>