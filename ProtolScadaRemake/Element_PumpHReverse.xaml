<UserControl x:Class="ProtolScadaRemake.Element_PumpHReverse"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProtolScadaRemake"
      mc:Ignorable="d" 
      MouseDown="ValueLabel_Click" 
      Height="80">

    <Grid Width="80" Height="80" VerticalAlignment="Top" Margin="0,8,0,0"
          Background="Transparent">
        <!-- Добавьте прозрачный фон -->

        <!-- Тэг сверху по центру -->
        <TextBlock x:Name="TAGNAME" 
                   TextWrapping="NoWrap" 
                   Text="TAG" 
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontFamily="Arial" 
                   FontSize="10"
                   Foreground="White" 
                   TextAlignment="Center"
                   Margin="0,0,0,0"/>

        <!-- Насос с поворотом внизу -->
        <Grid Width="60" Height="60" 
              HorizontalAlignment="Center" 
              VerticalAlignment="Bottom"
              Margin="0,0,0,0"
              IsHitTestVisible="False">
            <!-- Отключите клики для вложенного грида -->
            <Grid.RenderTransform>
                <RotateTransform Angle="180" CenterX="30" CenterY="30"/>
            </Grid.RenderTransform>

            <Image x:Name="PumpIcon"  
                   Source="{StaticResource PumpHStopIcon}" 
                   Width="60" 
                   Height="60" Margin="0,8,0,-8"
                   IsHitTestVisible="False"/>
        </Grid>

        <!-- Рука в правом нижнем углу -->
        <Image x:Name="HandImage" 
               Height="24" 
               Width="20" 
               Source="/Hand.png"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,10,10"
               IsHitTestVisible="False"/>
    </Grid>
</UserControl>