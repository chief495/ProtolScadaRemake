<UserControl x:Class="ProtolScadaRemake.Element_LT"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ProtolScadaRemake"
             mc:Ignorable="d" d:DesignWidth="136" 
             Background="#FF0C2948" Height="78">
    <Grid Width="136" Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="Description" HorizontalAlignment="Left" Margin="71,7,0,0" TextWrapping="Wrap" Text="Уровень" VerticalAlignment="Top" Height="20" Width="65" FontFamily="Arial" Foreground="White" TextAlignment="Center" />
        <TextBlock x:Name="TagName" HorizontalAlignment="Left" Text="###" VerticalAlignment="Top" Height="17" RenderTransformOrigin="0,0" Width="60" FontFamily="Arial" Foreground="White" TextAlignment="Center" Margin="0,7,0,0"/>
        <Rectangle HorizontalAlignment="Center" Height="38" Margin="0,32,0,0" Stroke="#FF267ABB" VerticalAlignment="Top" Width="130" Fill="#FF0D0C27" RadiusX="10" RadiusY="10"/>
        <Rectangle HorizontalAlignment="Left" Height="38" Margin="79,32,0,0" Stroke="#FF267ABB"  VerticalAlignment="Top" Width="54" RadiusX="10" RadiusY="10"/>

        <TextBlock x:Name="Value" HorizontalAlignment="Left" Margin="10,43,0,0" TextWrapping="Wrap" Text="{Binding TElementLT.ValueString}" VerticalAlignment="Top" Height="17" Width="65" Foreground="White" TextAlignment="Right" FontFamily="Arial" FontSize="14"/>
        <TextBlock HorizontalAlignment="Left" Margin="99,43,0,0" TextWrapping="Wrap" Text="мм" VerticalAlignment="Top" Foreground="White" FontFamily="Arial" Height="19"/>
    </Grid>

</UserControl>
