<UserControl x:Class="ProtolScadaRemake.Element_PumpUz"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProtolScadaRemake"
      mc:Ignorable="d" MouseDown="ValueLabel_Click" Height="80">

    <Grid Width="184" Height="80" VerticalAlignment="Center" HorizontalAlignment="Left">
        <!-- Иконка насоса -->
        <Image x:Name="PumpIcon" 
               Source="{StaticResource PumpHStopIcon}" 
               Width="60" 
               Height="60" 
               Margin="0,0,0,8" 
               VerticalAlignment="Bottom" 
               HorizontalAlignment="Left"/>

        <!-- Иконка руки (ручной режим) -->
        <Image x:Name="HandImage" 
               HorizontalAlignment="Left" 
               Height="24" 
               Margin="62,3,0,0" 
               VerticalAlignment="Top" 
               Width="20" 
               Source="/Hand.png"/>

        <!-- Имя тега -->
        <TextBlock x:Name="TAGNAME" 
                   TextWrapping="Wrap" 
                   Text="TAG" 
                   VerticalAlignment="Top" 
                   Width="60" 
                   HorizontalAlignment="Left" 
                   FontFamily="Arial" 
                   Foreground="White" 
                   TextAlignment="Center"/>

        <!-- Панель скорости с закруглёнными краями -->
        <Border CornerRadius="6"
                Background="#FF404040"
                BorderBrush="#FF5D5D5D"
                BorderThickness="1"
                Height="20"
                Width="90"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="62,32,0,0"
                ClipToBounds="True">

            <!-- Заполнение (зелёное) -->
            <Border x:Name="SpeedFill"
                    CornerRadius="5"
                    Background="#FF1E5945"
                    HorizontalAlignment="Left"
                    Width="0"
                    Margin="1"/>
        </Border>

        <!-- Текст скорости -->
        <TextBlock x:Name="SpeedText" 
                   HorizontalAlignment="Left" 
                   Margin="67,35,0,0" 
                   TextWrapping="Wrap" 
                   Text="0 %"
                   FontFamily="Arial"
                   FontSize="12"
                   FontWeight="SemiBold"
                   Foreground="White"
                   VerticalAlignment="Top"/>
    </Grid>
</UserControl>