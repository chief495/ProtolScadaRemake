<Window xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"  x:Class="ProtolScadaRemake.DialogElementValve"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProtolScadaRemake"
        mc:Ignorable="d"
        Title="DialogElementValve" Height="182" Width="671" Background="#FFCCC9C9" FontFamily="Arial" Margin="0,0,0,10"
        Icon="Images/ProtolLogo.ico">
    <Grid Margin="0,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>
        <GroupBox x:Name ="GroupBox1" Header="Режим работы" Margin="10,10,360,17">
            <StackPanel Height="120">
                <StackPanel Height="46" Margin="0,10,0,0">
                    <RadioButton x:Name="RBAuto" Content="Автоматический" Margin="10,0,0,0" Checked="RBAuto_CheckedChanged" />
                    <RadioButton x:Name="RBManual" Content="Ручной" Margin="10,10,0,0" Checked="RBManual_CheckedChanged" />
                </StackPanel>
                <StackPanel Height="34" Orientation="Horizontal" Margin="0,10,0,0" Width="222">
                    <Button x:Name="OpenButton" Content="Открыть" Width="100" Click="OpenButton_Click" />
                    <Button x:Name="CloseButton" Content="Закрыть" Width="100" Margin="20,0,0,0" Click="CloseButton_Click"  />
                </StackPanel>

            </StackPanel>
        </GroupBox>
        <GroupBox x:Name="GroupBox2" Header="Время вработы клапана" Margin="320,10,0,25">
            <StackPanel Height="84">
                <StackPanel Orientation="Horizontal" Height="39">
                    <TextBlock TextWrapping="Wrap" Text="Время открытия: " Width="123" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Controls:NumericUpDown x:Name="OpenTimeNumeric" Width="155" Height="23" Background="White" Maximum="1000" Minimum="0" StringFormat="##0" ValueChanged="OpenTimeNumeric_ValueChanged"/>
                    <TextBlock TextWrapping="Wrap" Text="сек." Height="18" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Height="39">
                    <TextBlock TextWrapping="Wrap" Text="Время закрытия: " Width="123" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Controls:NumericUpDown x:Name="CloseTimeNumeric" Width="155" Height="23" Background="White" StringFormat="##0" Maximum="1000" Minimum="0" ValueChanged="CloseTimeNumeric_ValueChanged"/>
                    <TextBlock TextWrapping="Wrap" Text="сек." Height="18" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
